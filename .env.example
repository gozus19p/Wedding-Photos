# ── Cloudflare R2 ───────────────────────────────────────────────
# Da: Cloudflare Dashboard → R2 → Manage R2 API Tokens
R2_ENDPOINT_URL=...
R2_ACCESS_KEY_ID=...
R2_SECRET_ACCESS_KEY=...
R2_BUCKET_NAME=...
# URL pubblico del bucket (abilita "Public access" in R2 per ottenerlo)
R2_PUBLIC_BASE_URL=...

# ── CLIP (opzionale) ────────────────────────────────────────────
